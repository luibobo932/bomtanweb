# ============================================================
# BomTan Web — Environment Variables
# Sao chép file này thành .env.local và điền giá trị thật
# Xem hướng dẫn chi tiết tại docs/deploy-checklist.md
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Lấy tại: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
# Chỉ dùng server-side, KHÔNG đặt NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# ── Site URL ────────────────────────────────────────────────
# Dùng cho canonical URL, OG tags, sitemap
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Zalo ────────────────────────────────────────────────────
# Số điện thoại Zalo hoặc link OA: https://zalo.me/XXXXXXXXXX
NEXT_PUBLIC_ZALO_URL=https://zalo.me/0000000000

# ── Tawk.to Live Chat ───────────────────────────────────────
# Lấy tại: Tawk.to Dashboard → Administration → Chat Widget
NEXT_PUBLIC_TAWKTO_PROPERTY_ID=YOUR_PROPERTY_ID
NEXT_PUBLIC_TAWKTO_WIDGET_ID=default

# ── Resend (Email thông báo lead) ───────────────────────────
# Đăng ký tại resend.com — free 3,000 email/tháng
RESEND_API_KEY=re_YOUR_API_KEY
RESEND_FROM_EMAIL=noreply@your-domain.com
ADMIN_NOTIFY_EMAIL=your-email@gmail.com
